# AI 小说推文自动化 - 环境变量配置
# 复制此文件为 .env 并填入你的 API Key
# cp .env.example .env

# === LLM 后端（至少设一个，用于智能分段和 Prompt 生成）===
# 不设则使用 simple 分段 + 本地关键词 Prompt（无需 API）
# 设置多个时，自动按优先级选择: Gemini → DeepSeek → OpenAI → Ollama

# Google Gemini（免费 1000次/天，推荐）
# 申请: https://aistudio.google.com/apikey
# GEMINI_API_KEY=

# DeepSeek（极低成本）
# 申请: https://platform.deepseek.com/api_keys
# DEEPSEEK_API_KEY=

# OpenAI
# 申请: https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# === 图片生成后端（至少设一个）===

# 硅基流动 SiliconFlow（免费，推荐）
# 申请: https://cloud.siliconflow.cn/account/ak
# SILICONFLOW_API_KEY=

# 阿里云百炼 DashScope（新用户 100 张免费）
# 申请: https://dashscope.console.aliyun.com/apiKey
# DASHSCOPE_API_KEY=

# Together.ai（需绑卡）
# 申请: https://api.together.ai/settings/api-keys
# TOGETHER_API_KEY=

# 本地 Diffusers 不需要 API Key
